{
  "name": "@yangshengzhou/leafcli",
  "version": "1.0.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Make any website or Electron App your CLI. AI-powered.",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "dist/src/main.js",
  "bin": {
    "leafcli": "dist/src/main.js"
  },
  "exports": {
    ".": "./dist/src/main.js",
    "./registry": "./dist/src/registry-api.js",
    "./errors": "./dist/src/errors.js",
    "./types": "./dist/src/types.js",
    "./utils": "./dist/src/utils.js",
    "./logger": "./dist/src/logger.js",
    "./launcher": "./dist/src/launcher.js",
    "./browser/cdp": "./dist/src/browser/cdp.js",
    "./browser/page": "./dist/src/browser/page.js",
    "./browser/utils": "./dist/src/browser/utils.js",
    "./download": "./dist/src/download/index.js",
    "./download/article-download": "./dist/src/download/article-download.js",
    "./download/media-download": "./dist/src/download/media-download.js",
    "./download/progress": "./dist/src/download/progress.js",
    "./pipeline": "./dist/src/pipeline/index.js"
  },
  "files": [
    "dist/src/",
    "clis/",
    "skills/",
    "cli-manifest.json",
    "scripts/",
    "docs/task-watcher-design.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "npm run clean-dist && npm run copy-yaml && npm run build-manifest",
    "build-manifest": "tsc --build && tsx src/build-manifest.ts",
    "clean-dist": "node scripts/clean-dist.cjs",
    "copy-yaml": "node scripts/copy-yaml.cjs",
    "start": "node dist/src/main.js",
    "postinstall": "node scripts/postinstall.js || true",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "browser",
    "web",
    "ai"
  ],
  "author": "yangshengzhou",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YangShengzhou03/LeafCLI.git"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^6.27.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.13",
    "jsdom": "^29.0.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "vitepress": {
      "vite": "6.4.2"
    }
  }
}
